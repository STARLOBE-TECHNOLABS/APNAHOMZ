RewriteEngine On

# 1. Force all requests to go through dist/
#    (Unless they are ALREADY in dist/, to avoid infinite loops)
RewriteCond %{REQUEST_URI} !^/dist/
RewriteRule ^(.*)$ dist/$1 [L]

# 2. Inside dist/, if a file exists, serve it.
#    (Apache handles this automatically if the path is correct,
#    but we might need to ensure the client doesn't see /dist/ in the URL)

# Wait, the above rule redirects /foo to dist/foo.
# If dist/foo exists, Apache serves it.
# If dist/foo does NOT exist (e.g. /login -> dist/login), we need to fallback to index.html

# Let's try a cleaner approach that masks /dist/

RewriteCond %{ENV:REDIRECT_STATUS} ^$
RewriteRule ^dist/ - [L,R=404]

RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ dist/$1 [L]

RewriteCond %{REQUEST_URI} !^/dist/
RewriteRule ^ dist/index.html [L]
