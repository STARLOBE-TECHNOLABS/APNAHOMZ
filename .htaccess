<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    Options -MultiViews

    # 1. If the request is for the root, serve dist/index.html
    RewriteRule ^$ dist/index.html [L]

    # 2. If the requested file exists in the 'dist' directory, serve it from there
    #    (e.g., /assets/main.js -> /dist/assets/main.js)
    RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f
    RewriteRule ^(.*)$ dist/$1 [L]

    # 3. If the requested resource exists as a real file/directory in the root, serve it directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4. Fallback: For any other request (like /login, /register), serve dist/index.html
    #    This allows React Router to handle the routing on the client side.
    RewriteRule ^ dist/index.html [L]
</IfModule>
